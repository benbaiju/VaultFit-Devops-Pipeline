# Copy to .env in the repo root (same folder as docker-compose.yml).
# Docker Compose loads .env automatically for variable substitution and passes
# these values into the backend container.
#
#   cp .env.docker.example .env
#
# Required: Supabase project keys (Dashboard → Project Settings → API).

# --- Backend (Express API) ---
PORT=4000
NODE_ENV=production
PAYMENTS_MODE=mock
VERIFICATION_DOCS_BUCKET=credential-docs
CHAT_MEDIA_BUCKET=chat-media

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optional: verify JWTs locally (Dashboard → API → JWT Secret)
# SUPABASE_JWT_SECRET=your-jwt-secret

# Optional: readiness probe timeout (ms) for GET /health/ready
# HEALTH_READY_TIMEOUT_MS=8000
