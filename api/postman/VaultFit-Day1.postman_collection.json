            "url": "{{baseUrl}}/trainers/{{trainerProfileId}}/availability"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Create availability returns 201 or 400', function () { pm.expect([201,400]).to.include(pm.response.code); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /trainers/:id/availability",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/trainers/{{trainerProfileId}}/availability"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('List availability status 200', function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /trainers/:id/blocked-dates",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{trainerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"blockedDate\": \"2026-04-28\",\n  \"reason\": \"Unavailable\"\n}"
            },
            "url": "{{baseUrl}}/trainers/{{trainerProfileId}}/blocked-dates"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Block date returns 201 or 400', function () { pm.expect([201,400]).to.include(pm.response.code); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "06 Bookings",
      "item": [
        {
          "name": "POST /bookings (valid slot)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clientToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trainerId\": \"{{trainerProfileId}}\",\n  \"bookingDate\": \"2026-04-27\",\n  \"startTime\": \"10:00:00\",\n  \"endTime\": \"11:00:00\",\n  \"notes\": \"First session\"\n}"
            },
            "url": "{{baseUrl}}/bookings"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Create booking status 201', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('bookingId', body.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /bookings (client)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clientToken}}" }],
            "url": "{{baseUrl}}/bookings"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('List bookings status 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('Booking present', function () { pm.expect(body.some((b) => b.id === pm.collectionVariables.get('bookingId'))).to.eql(true); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /bookings (blocked date - negative)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clientToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trainerId\": \"{{trainerProfileId}}\",\n  \"bookingDate\": \"2026-04-28\",\n  \"startTime\": \"10:00:00\",\n  \"endTime\": \"11:00:00\"\n}"
            },
            "url": "{{baseUrl}}/bookings"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Blocked date rejected', function () { pm.expect([400,409]).to.include(pm.response.code); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "07 Payments (Mock)",
      "item": [
        {
          "name": "POST /payments/initiate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clientToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{bookingId}}\",\n  \"amount\": 90,\n  \"currency\": \"AUD\"\n}"
            },
            "url": "{{baseUrl}}/payments/initiate"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Payment initiated status 201', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('paymentId', body.payment.id);",
                  "pm.test('Payment provider is mock', function () { pm.expect(body.payment.provider).to.eql('mock'); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /bookings (trainer view confirmed)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{trainerToken}}" }],
            "url": "{{baseUrl}}/bookings"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Trainer bookings status 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "const booking = body.find((b) => b.id === pm.collectionVariables.get('bookingId'));",
                  "pm.test('Booking moved to confirmed', function () { pm.expect(booking && booking.status).to.eql('confirmed'); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
