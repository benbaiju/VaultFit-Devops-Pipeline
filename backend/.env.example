# Copy to backend/.env for local development (npm run dev in backend/).
PORT=4000
NODE_ENV=development
HOST=0.0.0.0
PAYMENTS_MODE=mock
VERIFICATION_DOCS_BUCKET=credential-docs
CHAT_MEDIA_BUCKET=chat-media

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optional: JWT Secret from Supabase Dashboard → Project Settings → API
# SUPABASE_JWT_SECRET=
