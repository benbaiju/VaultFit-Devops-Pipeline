        {
          "name": "GET /trainers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/trainers"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('List trainers status 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "if (!pm.collectionVariables.get('trainerProfileId') && Array.isArray(body) && body.length > 0) {",
                  "  const match = body.find((t) => t.user_id === pm.collectionVariables.get('trainerUserId'));",
