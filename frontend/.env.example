VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY
# Optional. If unset in dev, the app uses same-origin /api (Vite proxies to 127.0.0.1:4000).
# Set this when the UI is not served by Vite (e.g. production build) or the API is on another host.
# VITE_API_URL=http://127.0.0.1:4000
#
# Override where Vite proxies /api in dev (default http://127.0.0.1:4000).
# VITE_DEV_API_PROXY=http://127.0.0.1:4000
#
# Optional; default 25000. Prevents the UI hanging forever if the API is down or unreachable.
# VITE_API_TIMEOUT_MS=25000
