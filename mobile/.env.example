# Backend base URL — no trailing slash. Baked into the JS bundle at Expo start/build time.

# Same Wi‑Fi as your computer (backend on LAN):
# EXPO_PUBLIC_API_URL=http://192.168.0.163:4000

# HTTPS tunnel from repo root (`npm run dev:cloudflare`) — copy the **cf-api** trycloudflare.com URL:
EXPO_PUBLIC_API_URL=https://xxxx.trycloudflare.com

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
